#!/bin/bash

set -e

workDir="$(pwd)"

if [[ "$(basename "$workDir")" == "bin" ]]; then
  cd ..
  workDir="$(pwd)"
fi

if ! command -v git >/dev/null 2>&1; then
  echo "::CBC::❌::> ERROR: This update script requires git. Please install git and try again."
  exit 1
fi

if [ ! -f 'button_landscape.yaml' ]; then
  echo "::CBC::❌::> ERROR: This command must be run in the directory containing the Creative Button-Card Templates!"
  exit 1
fi

if [ ! -d '.git' ]; then
  echo "::CBC::❌::> ERROR: No git repository found. Please run the install script first."
  exit 1
fi

if [[ -n "$(git status --porcelain --untracked-files=no)" ]]; then
  echo "::CBC::⚠️::> WARNING: You have modified the core files! If you continue with the update, your changes will be lost. Continue? (y/n)"
  read -r response
  if [[ "$response" != "y" ]]; then
    echo ":::CBC::❌::> Update cancelled. Please commit or stash your changes before updating."
    exit 1
  fi
fi

branch="$(git branch --show-current)"

if [[ "$1" != '--beta' ]] && [[ "$branch" != "master" ]]; then
  echo "::CBC::⚠️::> WARNING: You are not on the master branch! If you continue with the update, your changes might be lost. Continue? (y/n)"
  read -r response
  if [[ "$response" != "y" ]]; then
    echo ":::CBC::❌::> Update cancelled. Please commit or stash your changes before updating."
    exit 1
  fi
fi

echo ":::CBC::✅::> Updating Creative Button-Card Templates..."
git reset --hard

stashBefore="$(git rev-parse -q --verify refs/stash || true)"
git stash push -u -m "CBC update backup"
stashAfter="$(git rev-parse -q --verify refs/stash || true)"

if [ "$1" == '--beta' ]; then
  echo ":::CBC::⚠️::> You are updating to a beta version from $branch branch. This may include breaking changes and is not recommended for production use."
else
  git checkout master
fi

git pull origin --force || {
  echo ""
  echo "::CBC::❌::> Failed to pull latest changes. Please check your internet connection and try again."
  exit 1
}
if [[ "$stashAfter" != "$stashBefore" ]]; then
  git stash pop 'stash@{0}'
fi

if [[ -f "custom/cbc_settings.yaml" ]]; then
  echo ":::CBC::⚠️::> Your existing cbc_settings.yaml file has been preserved. Please review it against the sample and make any necessary adjustments to new settings added in the update."
else
  cp -f custom/cbc_settings.sample custom/cbc_settings.yaml
  echo ":::CBC::✅::> A new cbc_settings.yaml file has been created from the sample. Please review and adjust settings as needed."
fi

echo ":::CBC::✅::> Update complete!"
echo ''
echo ":::CBC::> Would you also like to update cbc.yml? This is the file you can copy and paste in your Home Asssistant dashboard configuration. (y/n)"
read -r response
if [[ "$response" == "y" ]]; then
  bin/export
fi